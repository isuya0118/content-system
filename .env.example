# ─── WordPress ─────────────────────────────────────────
WP_BASE_URL=https://isuya0118.com

# Jetpack PV 取得用（任意）
# 取得方法：WordPress管理画面 → ユーザー → プロフィール → アプリケーションパスワード
WP_USERNAME=your_wp_username_here
WP_APP_PASSWORD=your_app_password_here

# ─── note ──────────────────────────────────────────────
NOTE_CREATOR=seminomise

# ─── X ─────────────────────────────────────────────────
X_USERNAME=isuya0118

# X API v2 Bearer Token（X の自動取得に必須）
# 取得方法：https://developer.twitter.com/en/portal/dashboard
# 1. developer.twitter.com でプロジェクトを作成
# 2. "Keys and Tokens" から Bearer Token をコピー
X_BEARER_TOKEN=your_bearer_token_here
